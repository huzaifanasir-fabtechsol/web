# EquiManage Django Environment variables Example
# Copy this file to '.env' and modify settings for your environment

# -----------------
# Core Django Config
# -----------------
# Set to False in production! Set to True for local development.
DEBUG=True

# In production, use a secure, unique, and long random key (e.g. generated via openssl rand -hex 32)
SECRET_KEY=django-insecure-4i=ci^s2c=f7)@yv+u9ez8x=@ls5-cwvbg*(%yln4dxcv50gp9

# Comma-separated list of hosts/IPs that are allowed to access the backend.
# Required when DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.equimanage.com,your-vps-ip

# -----------------
# Database Config
# -----------------
# Database URL Option (Recommended for production):
# For PostgreSQL: postgres://username:password@hostname:port/database_name
# For SQLite: sqlite:///db.sqlite3
# DATABASE_URL=postgres://equimanage_user:yourpassword@localhost:5432/equimanage_db

# Alternative Individual Database Variables:
# DB_NAME=equimanage_db
# DB_USER=equimanage_user
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# -----------------
# CORS Config
# -----------------
# Comma-separated list of origins allowed to make cross-site requests to this API.
# Should include your Vercel frontend URL, and any local test URLs.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://equimanage-web.vercel.app

# Set to True to allow requests from any origin (e.g. file:// or null origins sent by the Electron app).
# Note: Use this with caution. If True, CORS_ALLOWED_ORIGINS is ignored.
CORS_ALLOW_ALL_ORIGINS=True

# -----------------
# Email Config
# -----------------
# Default from email header
DEFAULT_FROM_EMAIL=noreply@equimanage.com

# -----------------
# Frontend Config
# -----------------
# The URL of your primary frontend (used in emails or template redirects if needed)
FRONTEND_URL=https://equimanage-web.vercel.app
